# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Razorpay — from https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Sender address — use onboarding@resend.dev for testing, or your verified domain
RESEND_FROM_EMAIL=Kickd <orders@yourdomain.com>

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
